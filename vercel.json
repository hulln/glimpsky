{
  "redirects": [
    {
      "source": "/sl",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/sl/",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/sl/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/sl/bluesky-profile-viewer",
      "destination": "/guides/bluesky-profile-viewer/",
      "permanent": true
    },
    {
      "source": "/sl/bluesky-profile-viewer/",
      "destination": "/guides/bluesky-profile-viewer/",
      "permanent": true
    },
    {
      "source": "/sl/bluesky-likes-viewer",
      "destination": "/guides/bluesky-likes-viewer/",
      "permanent": true
    },
    {
      "source": "/sl/bluesky-likes-viewer/",
      "destination": "/guides/bluesky-likes-viewer/",
      "permanent": true
    },
    {
      "source": "/sl/how-to-see-bluesky-likes",
      "destination": "/guides/bluesky-likes-viewer/",
      "permanent": true
    },
    {
      "source": "/sl/how-to-see-bluesky-likes/",
      "destination": "/guides/bluesky-likes-viewer/",
      "permanent": true
    },
    {
      "source": "/sl/:path*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/guides/how-to-see-bluesky-likes",
      "destination": "/guides/bluesky-likes-viewer/",
      "permanent": true
    },
    {
      "source": "/guides/how-to-see-bluesky-likes/",
      "destination": "/guides/bluesky-likes-viewer/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)\\.(js|css)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)\\.(svg|png|jpg|jpeg|webp|ico)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/llms.txt",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ]
}
